# 🐕 ClawGuard 配置文件示例
# 复制此文件为 monitor.conf 并修改配置

# ============ 阈值配置 ============
MEMORY_THRESHOLD=1500
RESPONSE_THRESHOLD=3000
DISK_THRESHOLD=85
ERROR_THRESHOLD=10

# ============ 慢响应重启配置 (可选) ============
# Gateway 响应超过此阈值时计数，连续3次触发重启
SLOW_RESPONSE_THRESHOLD=30000  # 毫秒 (默认30秒)
SLOW_RESPONSE_COUNT=3           # 连续异常次数

# ============ 已知任务 ============
# 空格分隔的任务名，监控会检测这些任务的执行状态
KNOWN_JOBS="cron-monitor openclaw-maintenance 看门狗"

# ============ 告警配置 ============
# 修改为你的QQ号或企微账号
ALERT_TARGET="qqbot:c2c:YOUR_QQ_ID"

# ============ 自监控 ============
# 防止重复运行
SELF_CHECK=true

# ============ 错误趋势 (可选) ============
ERROR_TREND_WINDOW=5
ERROR_TREND_THRESHOLD=3

# ============ 通道健康权重 (可选) ============
CHANNEL_HEALTH_WEIGHT_ERROR=30
CHANNEL_HEALTH_WEIGHT_TIMEOUT=50

# ============ 集群模式 (可选) ============
# 多实例监控
CLUSTER_MODE=false
CLUSTER_INSTANCES=""

# ============ 备用告警通道 ============
# Webhook: 自定义告警回调 (企业微信/钉钉/Slack等)
WEBHOOK_ENABLED=false
WEBHOOK_URL=""

# 邮件: 系统需安装 mailx
EMAIL_ENABLED=false
EMAIL_TO=""

# ============ 使用说明 ============
# 1. 配置热加载: kill -SIGHUP $(pgrep -f openclaw-monitor.sh)
# 2. 环境变量覆盖: export MEMORY_THRESHOLD=2000
# 3. 容器化: docker run -e MEMORY_THRESHOLD=2000 ...
